rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. usernames 컬렉션 규칙 (username과 uid 매핑 인덱스 테이블)
    match /usernames/{username} {
      // 읽기: 누구나 가능 (공유 페이지 조회 시 uid 변환 및 중복 가입 방지를 위해 비로그인 유저도 조회 가능)
      allow read: if true;
      
      // 쓰기: 로그인 필수, 새로 입력되는 데이터의 uid 값이 본인의 uid와 일치해야 함
      allow write: if request.auth != null && request.resource.data.uid == request.auth.uid;
    }

    // 2. users 컬렉션 및 하위 서브컬렉션 규칙
    match /users/{userId} {
      
      // users/{userId} 계정 자체의 문서 제어
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // profile 서브컬렉션 규칙 (users/{userId}/profile/info)
      match /profile/{profileDoc} {
        // 읽기: 누구나 가능 (비로그인 방문자도 프로필 조회가 가능해야 하므로)
        allow read: if true;
        
        // 쓰기(생성, 수정, 삭제): 로그인 필수이며 본인의 프로필 문서만 제어 가능
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // links 서브컬렉션 규칙 (users/{userId}/links/{linkId})
      match /links/{linkId} {
        // 읽기: 누구나 가능 (비로그인 방문자도 사용자 링크트리 바로가기를 볼 수 있어야 하므로)
        allow read: if true;
        
        // 쓰기(생성, 수정, 삭제): 로그인 필수이며 본인의 링크 리스트만 제어 가능
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
